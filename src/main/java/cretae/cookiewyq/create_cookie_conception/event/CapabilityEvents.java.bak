package cretae.cookiewyq.create_cookie_conception.event;

import cretae.cookiewyq.create_cookie_conception.CookieConceptionMod;
import cretae.cookiewyq.create_cookie_conception.blockentity.TieredContainerBlockEntity;
import cretae.cookiewyq.create_cookie_conception.blocks.ModBlocks;
import net.neoforged.bus.api.SubscribeEvent;
import net.neoforged.fml.common.EventBusSubscriber;
import net.neoforged.neoforge.capabilities.Capabilities;
import net.neoforged.neofforge.event.capabilities.RegisterCapabilitiesEvent;

@EventBusSubscriber(modid = CookieConceptionMod.MODID)
public class CapabilityEvents {
    @SubscribeEvent
    public static void registerCapabilities(RegisterCapabilitiesEvent event) {
        // Register item handler for tiered containers
        event.registerBlockEntity(
                Capabilities.ItemHandler.BLOCK,
                ModBlockEntities.TIERED_CONTAINER.get(),
                (be, side) -> be.getItemHandler()
        );

        // Register fluid handler for tiered containers
        event.registerBlockEntity(
                Capabilities.FluidHandler.BLOCK,
                ModBlockEntities.TIERED_CONTAINER.get(),
                (be, side) -> be.getFluidHandler()
        );
    }
}
