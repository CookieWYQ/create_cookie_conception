package cretae.cookiewyq.create_cookie_conception.compat;

import cretae.cookiewyq.create_cookie_conception.blockentity.TieredContainerBlockEntity;
import net.minecraft.nbt.CompoundTag;
import net.minecraft.network.chat.Component;
import net.neoforged.neoforge.items.ItemStackHandler;
import net.neoforged.neoforge.fluids.FluidTank;
import snownee.jade.api.*;
import snownee.jade.api.config.IWailaConfig;

@WailaPlugin
public class JadePlugin implements IWailaPlugin {

    @Override
    public void register(IWailaCommonRegistrar registrar) {
        registrar.registerBlockDataProvider(TieredContainerProvider.INSTANCE, TieredContainerBlockEntity.class);
    }

    @Override
    public void registerClient(IWailaClientRegistrar registrar) {
        registrar.registerBlockComponent(TieredContainerProvider.INSTANCE,
                cretae.cookiewyq.create_cookie_conception.blocks.tiered.TieredContainerBlock.class);
    }

    public enum TieredContainerProvider implements IBlockComponentProvider, IServerDataProvider<BlockAccessor> {
        INSTANCE;

        @Override
        public void appendTooltip(ITooltip tooltip, BlockAccessor accessor, IPluginConfig config) {
            if (accessor.getServerData().contains("tieredcontainer")) {
                CompoundTag data = accessor.getServerData().getCompound("tieredcontainer");
                int itemSlots = data.getInt("itemSlots");
                int filledSlots = data.getInt("filledSlots");
                tooltip.add(Component.translatable("jade.create_cookie_conception.items", filledSlots, itemSlots));

                CompoundTag fluids = data.getCompound("fluids");
                for (String key : fluids.getAllKeys()) {
                    CompoundTag tank = fluids.getCompound(key);
                    int amount = tank.getInt("amount");
                    int capacity = tank.getInt("capacity");
                    String fluidName = tank.getString("name");
                    tooltip.add(Component.literal(fluidName + ": " + amount + " / " + capacity + " mB"));
                }
            }
        }

        @Override
        public void appendServerData(CompoundTag data, BlockAccessor accessor) {
            if (accessor.getBlockEntity() instanceof TieredContainerBlockEntity be) {
                CompoundTag modData = new CompoundTag();
                ItemStackHandler items = be.getItemHandler();
                int filled = 0;
                for (int i = 0; i < items.getSlots(); i++)
                    if (!items.getStackInSlot(i).isEmpty()) filled++;
                modData.putInt("itemSlots", items.getSlots());
                modData.putInt("filledSlots", filled);

                CompoundTag fluidsTag = new CompoundTag();
                java.util.List<FluidTank> tanks = be.getFluidTanks();
                for (int i = 0; i < tanks.size(); i++) {
                    FluidTank tank = tanks.get(i);
                    CompoundTag tankTag = new CompoundTag();
                    tankTag.putInt("amount", tank.getFluidAmount());
                    tankTag.putInt("capacity", tank.getCapacity());
                    tankTag.putString("name", tank.getFluid().getHoverName().getString());
                    fluidsTag.put("tank" + i, tankTag);
                }
                modData.put("fluids", fluidsTag);
                data.put("tieredcontainer", modData);
            }
        }
    }
}
